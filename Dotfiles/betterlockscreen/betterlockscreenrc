# ~/.config/betterlockscreenrc

# default options
display_on=0
span_image=false
lock_timeout=300
fx_list=(dim blur dimblur pixel dimpixel color)
dim_level=40
blur_level=1
pixel_scale=10,1000
solid_color=333333
wallpaper_cmd="feh --bg-fill"
quiet=false

# --- Background and Box ---
loginbox=1e1e2e66
loginshadow=00000000
bgcolor=1e1e2eff

# --- Text and Font ---
# Shortened text to prevent overlap with the ring
locktext="Type Password..."
font="JetBrainsMono Nerd Font"
timecolor=cdd6f4ff
time_format="%H:%M:%S"
greetercolor=cdd6f4ff
layoutcolor=cdd6f4ff

# --- Normal State (Idle & Typing) ---
# Ring is a subtle grey (Surface1), so the Mauve highlight is visible
ringcolor=45475aff
insidecolor=00000000
separatorcolor=00000000

# Typing highlight (Mauve) and Backspace highlight (Red)
keyhlcolor=cba6f7ff
bshlcolor=f38ba8ff

# --- Verifying State ---
# Ring lights up Green (a6e3a1) when checking password
ringvercolor=a6e3a1ff
insidevercolor=00000000
veriftext="Verifying..."
verifcolor=cdd6f4ff

# --- Wrong Password State ---
# Ring flashes Red (f38ba8) on error
ringwrongcolor=f38ba8ff
insidewrongcolor=00000000
wrongtext="Failure!"
wrongcolor=f38ba8ff

# --- Modifiers (e.g., Caps Lock) ---
# Peach color for caps lock warning
modifcolor=fab387ff


#
# expert options (change at own risk!)
#

# i3lockcolor_bin="i3lock-color"      # Manually set command for i3lock-color
# suspend_command="systemctl suspend" # Manually change action e.g. hibernate/suspend-command

# i3lock-color - custom arguments
# lockargs=() 						  # overwriting default "(-n)"
# lockargs+=(--ignore-empty-password) # appending new argument
